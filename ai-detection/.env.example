# ai-detection — переменные окружения для НЕЗАВИСИМОГО запуска
# (отдельный ПК / GPU-сервер / docker run / python main.py).
#
# Скопируй в `.env` рядом (в каталоге ai-detection/) и заполни под свой сервер.
# Реальный .env в git не попадёт (см. корневой .gitignore); коммитится только
# этот .env.example. Код ai-detection НЕ содержит хардкода адресов — всё отсюда.
#
# Использование:
#   docker compose -f docker-compose.standalone.yml --env-file .env up -d
#   ИЛИ:  docker run --env-file .env --gpus all ...  (см. README.md)
#   ИЛИ:  set -a; . ./.env; set +a; python main.py

# ---------- Redis (шина конфига камер + Streams событий) ----------
# На отдельном ПК укажи адрес Redis VPS (лучше через VPN, а не публично).
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------- MinIO / S3 (загрузка снимков и клипов) ----------
# Endpoint MinIO VPS, доступный этому серверу.
S3_ENDPOINT=http://127.0.0.1:9100
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=event-clips

# ---------- HTTP (health + приём test/snapshot от camera-service) ----------
# Порт, на котором ai-detection слушает (bind 0.0.0.0). Для функций
# «проверить камеру» и «снапшот» camera-service должен достучаться сюда.
PORT=8000

# ---------- AI / модели ----------
YOLO_DEVICE=cuda                                 # cuda | cpu
YOLO_MODEL=models/official/shopguard_v1.pt       # путь внутри контейнера/образа
MODELS_DIR=models
YOLO_CONFIDENCE=0.40

# ---------- A/B модели (опционально) ----------
AB_CANARY_MODEL=
AB_CANARY_PERCENT=0

# ---------- Тюнинг детекции / RTSP (опционально, есть дефолты в коде) ----------
CONFIG_REFRESH_SECONDS=30
THEFT_COOLDOWN_SECONDS=30
CLIP_BUFFER_SECONDS=10
CLIP_FPS=10
FACE_THRESHOLD=0.45
BLACKLIST_COOLDOWN_SECONDS=60
RECONNECT_MIN_SECONDS=2
RECONNECT_MAX_SECONDS=60
RTSP_OPEN_TIMEOUT_MS=10000
RTSP_READ_TIMEOUT_MS=10000
SEEN_TRACK_CAP=5000
