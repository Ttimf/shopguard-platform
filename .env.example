# Скопируй в .env. Значения по умолчанию заданы в docker-compose.yml.
POSTGRES_USER=shopguard
POSTGRES_PASSWORD=shopguard_secret
POSTGRES_DB=shopguard

REDIS_PASSWORD=redis_secret

# JWT (смени на длинные случайные строки)
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Ключ шифрования RTSP-URL камер (длинная случайная строка)
CAMERA_ENC_KEY=change_me_camera_enc_key_min_32_chars

S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=event-clips
# Публичный адрес MinIO для presigned-ссылок (доступен приложению)
S3_PUBLIC_ENDPOINT=http://localhost:9100

# Telegram-бот для алертов (получи токен у @BotFather). Пусто — Telegram выключен.
TELEGRAM_BOT_TOKEN=
