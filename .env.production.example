# Скопируй в .env.production и заполни. НИКОГДА не коммить реальные значения.
# Все секреты — длинные случайные строки: openssl rand -base64 48

# ---------- Домены / HTTPS ----------
API_DOMAIN=api.shopguard.example.com
FILES_DOMAIN=files.shopguard.example.com
ACME_EMAIL=admin@shopguard.example.com

# ---------- PostgreSQL ----------
POSTGRES_USER=shopguard
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=shopguard

# ---------- Redis ----------
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ---------- JWT (мин. 32 символа каждый) ----------
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_48+_chars
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_48+_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---------- Шифрование RTSP-кредов камер ----------
CAMERA_ENC_KEY=CHANGE_ME_camera_enc_key_48+_chars

# ---------- MinIO / S3 ----------
S3_ACCESS_KEY=CHANGE_ME_minio_access_key
S3_SECRET_KEY=CHANGE_ME_minio_secret_key
S3_BUCKET=event-clips

# ---------- Telegram (опционально) ----------
TELEGRAM_BOT_TOKEN=

# ---------- AI ----------
YOLO_DEVICE=cpu
