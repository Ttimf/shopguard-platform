{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/gateway/src",
  "monorepo": true,
  "root": "apps/gateway",
  "compilerOptions": {
    "webpack": true,
    "tsConfigPath": "tsconfig.build.json",
    "deleteOutDir": false
  },
  "projects": {
    "gateway": { "type": "application", "root": "apps/gateway", "entryFile": "main", "sourceRoot": "apps/gateway/src", "compilerOptions": { "tsConfigPath": "tsconfig.build.json" } },
    "auth": { "type": "application", "root": "apps/auth", "entryFile": "main", "sourceRoot": "apps/auth/src", "compilerOptions": { "tsConfigPath": "tsconfig.build.json" } },
    "user": { "type": "application", "root": "apps/user", "entryFile": "main", "sourceRoot": "apps/user/src", "compilerOptions": { "tsConfigPath": "tsconfig.build.json" } },
    "camera": { "type": "application", "root": "apps/camera", "entryFile": "main", "sourceRoot": "apps/camera/src", "compilerOptions": { "tsConfigPath": "tsconfig.build.json" } },
    "notification": { "type": "application", "root": "apps/notification", "entryFile": "main", "sourceRoot": "apps/notification/src", "compilerOptions": { "tsConfigPath": "tsconfig.build.json" } },
    "event": { "type": "application", "root": "apps/event", "entryFile": "main", "sourceRoot": "apps/event/src", "compilerOptions": { "tsConfigPath": "tsconfig.build.json" } },
    "storage": { "type": "application", "root": "apps/storage", "entryFile": "main", "sourceRoot": "apps/storage/src", "compilerOptions": { "tsConfigPath": "tsconfig.build.json" } },
    "common": { "type": "library", "root": "libs/common", "entryFile": "index", "sourceRoot": "libs/common/src", "compilerOptions": { "tsConfigPath": "tsconfig.build.json" } },
    "contracts": { "type": "library", "root": "libs/contracts", "entryFile": "index", "sourceRoot": "libs/contracts/src", "compilerOptions": { "tsConfigPath": "tsconfig.build.json" } }
  }
}
